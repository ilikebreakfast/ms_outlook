# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# --- Microsoft Azure App Registration ---
MS_CLIENT_ID=your-client-id-here
MS_TENANT_ID=consumers

# --- Mailbox ---
# Leave blank to use the default Inbox.
# Set to a folder name e.g. Orders to target a specific folder.
TARGET_FOLDER=

# --- OCR ---
# Leave as "tesseract" if it's on your PATH.
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=tesseract

# --- Antivirus (ClamAV) ---
# true  = scan every attachment with clamscan before processing (recommended)
# false = skip AV scan (use if ClamAV is not installed and you're not using Docker)
CLAMAV_ENABLED=false
# Leave as "clamscan" if on PATH. Windows example: C:\ClamAV\clamscan.exe
CLAMAV_CMD=clamscan

# --- Email movement ---
# true  = move emails to PROCESSED_FOLDER_NAME after processing (recommended)
# false = leave emails in place (SQLite dedup prevents reprocessing)
MOVE_AFTER_PROCESSING=true
PROCESSED_FOLDER_NAME=Processed-Pipeline
