# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# --- Microsoft Azure App Registration ---
MS_CLIENT_ID=your-client-id-here
MS_TENANT_ID=consumers

# --- Mailbox ---
# Leave blank to use the default Inbox.
# Set to a folder name e.g. Orders to target a specific folder.
TARGET_FOLDER=

# --- OCR ---
# Leave as "tesseract" if it's on your PATH.
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=tesseract

# --- Antivirus (ClamAV) ---
# true  = scan every attachment with clamscan before processing (recommended)
# false = skip AV scan (use if ClamAV is not installed and you're not using Docker)
CLAMAV_ENABLED=false
# Leave as "clamscan" if on PATH. Windows example: C:\ClamAV\clamscan.exe
CLAMAV_CMD=clamscan

# --- Email movement ---
# true  = move emails to PROCESSED_FOLDER_NAME after processing (recommended)
# false = leave emails in place (SQLite dedup prevents reprocessing)
MOVE_AFTER_PROCESSING=true
PROCESSED_FOLDER_NAME=Processed-Pipeline

# --- Scheduling (daemon mode) ---
# Interval in minutes when running with --schedule flag or via the Docker scheduler service.
DEFAULT_SCHEDULE_MINUTES=60

# --- Customer onboarding automation ---
# Set to a value between 0.0 and 1.0.
# When a suggested template's field-extraction confidence meets this threshold,
# it is automatically promoted to config/templates/ and the sender is added to
# address_book.json without manual intervention.
# 0 (default) disables auto-approval entirely — all suggestions require manual review.
# 0.85 is a reasonable starting point for high-confidence auto-approval.
AUTO_APPROVE_CONFIDENCE=0

# --- Notifications ---
# Optional: POST a run summary to this URL after every pipeline run.
# Supports Slack incoming webhooks, Microsoft Teams connectors, n8n, etc.
# Leave blank to disable.
WEBHOOK_URL=

# Optional: separate URL for urgent alerts (auth failures, large review queue).
# Falls back to WEBHOOK_URL if not set.
ALERT_WEBHOOK_URL=

# --- Claude AI reviewer (fallback for low-confidence / no-template results) ---
# Requires an Anthropic API key: https://console.anthropic.com/
# Uses claude-haiku for cost efficiency — only invoked when regex confidence is low
# or when no YAML template exists for a sender.
#
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_REVIEW_ENABLED=false
#
# Confidence threshold below which Claude review is triggered (default: 0.6).
# Set lower (e.g. 0.4) to only use Claude for very poor matches, higher (0.8)
# to use it more aggressively.
# CLAUDE_REVIEW_THRESHOLD=0.6

# --- Classification: extra personal email domains ---
# Comma-separated list of additional domains treated as personal (matched by
# exact email address rather than domain).
# The built-in list covers: gmail.com, hotmail.com, outlook.com, yahoo.com,
# live.com, icloud.com, bigpond.com, optusnet.com.au
# Add extras here e.g: protonmail.com,zoho.com
PERSONAL_EMAIL_DOMAINS=
