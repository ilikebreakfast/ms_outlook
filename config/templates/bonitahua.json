{
  "_comment": "Copy this file, rename to your customer, fill in the fields.",
  "customer_name": "Bonita Hua",
  "sender_domains": ["bonitahua@hotmail.com"],
  "abns": [""],
  "keywords": ["bonita"],
  "required_fields": ["invoice_number", "order_date", "abn"],
  "fields": {
    "customer_name":           ["ACME\\s+Corp(?:oration)?"],
    "abn":                     ["ABN[:\\s]+(\\d[\\d\\s]{9,12}\\d)"],
    "address":                 ["(\\d+\\s+\\w+.*?(?:NSW|VIC|QLD|WA|SA|TAS|ACT|NT)\\s+\\d{4})"],
    "order_date":              ["(?:Order|Invoice)\\s+Date[:\\s]+(\\d{1,2}[/-]\\d{1,2}[/-]\\d{2,4})"],
    "requested_delivery_date": ["(?:Deliver(?:y)?\\s+(?:By|Date))[:\\s]+(\\d{1,2}[/-]\\d{1,2}[/-]\\d{2,4})"],
    "invoice_number":          ["(?:Invoice|INV|PO)[\\s#:.]*(\\w{4,20})"]
  },
  "line_items_pattern": "(?P<qty>\\d+(?:\\.\\d+)?)\\s+(?P<description>[A-Za-z][\\w\\s,.-]{3,60})\\s+\\$?(?P<unit_price>[\\d,]+\\.\\d{2})\\s+\\$?(?P<total>[\\d,]+\\.\\d{2})"
}
